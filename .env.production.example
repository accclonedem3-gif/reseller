# ── Reseller production env ──────────────────────────────────────────────────
# Copy this file to .env.production and fill the values. NEVER commit the real
# .env.production — it's gitignored.
#
# Generate secrets:
#   openssl rand -hex 32     ← JWT_*_SECRET, APP_ENCRYPTION_KEY, INTERNAL_API_TOKEN
#   openssl rand -hex 16     ← GROK_API_KEY, VEO_API_KEY

# ── Public URLs ───────────────────────────────────────────────────────────────
APP_PUBLIC_URL=https://api.your-domain.com
WEB_PUBLIC_URL=https://app.your-domain.com
CORS_ORIGIN=https://app.your-domain.com

# ── DB credentials ────────────────────────────────────────────────────────────
POSTGRES_USER=reseller
POSTGRES_PASSWORD=                              # REQUIRED, use openssl rand -hex 16
POSTGRES_DB=reseller

# ── Auth secrets ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                              # REQUIRED, 32 bytes hex
JWT_REFRESH_SECRET=                             # REQUIRED, 32 bytes hex
APP_ENCRYPTION_KEY=                             # REQUIRED, 32 bytes hex (encrypt seller bot tokens)
INTERNAL_API_TOKEN=                             # REQUIRED, 32 bytes hex (HMAC worker→api callback)

# ── Tool pool API keys (Cách 2 — tool servers protected from public access) ──
GROK_API_KEY=                                   # REQUIRED, 16 bytes hex
VEO_API_KEY=                                    # REQUIRED, 16 bytes hex

# ── Payment (PayOS or set PAYMENT_MODE=mock for testing) ─────────────────────
PAYMENT_MODE=payos
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ── DB pool ───────────────────────────────────────────────────────────────────
# Cap the Prisma connection pool so api + worker (catalog-sync concurrency + sweeps +
# account-check) can't exhaust Postgres max_connections. Append to DATABASE_URL, e.g.:
#   DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB?schema=public&connection_limit=5&pool_timeout=20
# (Prisma otherwise auto-sizes the pool to num_cpus*2+1 per process.)

# ── Scale knobs ──────────────────────────────────────────────────────────────
# ⚠️  4GB VPS (the pm2 ecosystem.config.cjs path): DO NOT set the concurrency/replica overrides
#     below — leave them UNSET and set DEPLOY_TIER=4gb instead. The ecosystem reads
#     `process.env.GROK_MAX_CONCURRENCY || T.grokConc`, so any value here OVERRIDES the 4GB tier
#     caps (grok-conc 6, veo-pool 2, worker-conc 3) → peak Chromium far exceeds 4GB → OOM.
#     The values below are sized for the SEPARATE 8GB+/docker-compose.production.yml path.
# Match the host's available memory:
#   8GB VPS: API_REPLICAS=2 WORKER_REPLICAS=1 grok-pool=1 veo-pool=1   ≈ 6GB allocated
#   16GB VPS: API_REPLICAS=2 WORKER_REPLICAS=1 grok-pool=2 veo-pool=1  ≈ 9GB allocated
#   32GB VPS: API_REPLICAS=3 WORKER_REPLICAS=2 grok-pool=3 veo-pool=2  ≈ 17GB allocated
API_REPLICAS=2
WORKER_REPLICAS=1
WEB_REPLICAS=2

# Tool concurrency: GROK_MAX_CONCURRENCY × replicas = total concurrent grok checks the pool
# can serve. Each Chrome ≈ 350MB RAM, so 6 concurrent × 1 replica ≈ 2GB peak per pool VPS.
GROK_MAX_CONCURRENCY=6
GROK_MAX_ACC_PER_JOB=10
VEO_POOL_MAX=2
VEO_MAX_CONCURRENCY=2

# Worker side parallelism (per worker replica):
#   BullMQ jobs concurrent × accounts per job parallelism = total Chrome-equivalent slots
WORKER_CHECK_CONCURRENCY=3
WORKER_PARALLEL_LIMIT=3

# Disable specific tools while their wrappers are unstable. CSV.
# Default: gpt off because check_gpt has no HTTP fast-path yet (only subprocess, fragile).
WARRANTY_DISABLED_TOOLS=gpt

# ── Tool proxy lists (file paths on host) ────────────────────────────────────
# Bind-mount these into the tool containers — hot-reloadable via /admin/reload-proxies.
GROK_PROXY_FILE=../CheckGrokJS/proxy.txt
VEO_PROXY_FILE=../check_veo/proxies.txt

# ── Ports (host-facing) ──────────────────────────────────────────────────────
API_PORT=3000
WEB_PORT=5173
