# Copy -> .env (cùng thư mục docker-compose.yml). KHÔNG commit .env thật.

# Khoá bảo vệ HTTP của 3 checker. Worker phải gửi đúng khoá này qua X-API-Key.
# Tạo chuỗi ngẫu nhiên mạnh, vd: openssl rand -hex 24
API_KEY=change-me-strong-random

# CF cookie warmer của grok (1 = bật 24/7, 0 = tắt)
GROK_WARMER=1
