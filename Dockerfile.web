# syntax=docker/dockerfile:1.6
# Web service: Vite/React SPA. Built with VITE_API_URL baked in, served by Caddy.

FROM node:22-bookworm-slim AS builder
WORKDIR /app
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

COPY package*.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web
COPY apps/api/package.json ./apps/api/package.json
COPY apps/worker/package.json ./apps/worker/package.json
# Prisma schema is read by root `npm run build` for the `prisma generate` step, but for
# the web image we skip that — only build shared + web.
COPY prisma/schema.prisma ./prisma/schema.prisma

RUN npm ci
RUN npm run build -w @reseller/shared
RUN npm run build -w @reseller/web

FROM caddy:2-alpine AS runtime
COPY --from=builder /app/apps/web/dist /srv

# Bind to Railway's $PORT (fallback 80 for local). SPA fallback to index.html.
RUN printf ':{$PORT:80} {\n\troot * /srv\n\ttry_files {path} /index.html\n\tfile_server\n\tencode gzip\n}\n' > /etc/caddy/Caddyfile

EXPOSE 80
