NODE_ENV=development

API_PORT=3000
WEB_PORT=5173
WORKER_PORT=3200

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reseller_platform?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reseller_platform
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
APP_ENCRYPTION_KEY=change-me-32-byte-key
INTERNAL_API_TOKEN=change-me-internal-api-token

APP_PUBLIC_URL=http://localhost:3000
WEB_PUBLIC_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000/api/v1
PASSWORD_RESET_TTL_MINUTES=30
RESEND_API_KEY=
MAIL_FROM=Reseller Platform <onboarding@resend.dev>

PAYMENT_MODE=payos
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Binance Pay Merchant API (auto flow — Phase A)
# Get these from Binance Merchant Admin Portal
# Docs: https://developers.binance.com/docs/binance-pay/authentication
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
# Webhook URL Binance sẽ gọi khi có PAY_SUCCESS
BINANCE_PAY_WEBHOOK_URL=https://yourdomain.com/api/v1/webhooks/binancepay
# (Optional) Nếu chỉ có 1 shop dùng Binance Pay, set shopId ở đây để bỏ qua DB lookup
BINANCE_PAY_SHOP_ID=
# Rate USDT/VND — dùng để convert VND → USDT khi tạo Binance Pay order
USDT_VND_RATE=26000

DEFAULT_PROVIDER_BASE_URL=https://canboso.com
DEFAULT_PROVIDER_NAME=canboso
DEFAULT_CURRENCY=VND
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000/uploads

SEED_SUPER_ADMIN_EMAIL=thaidem57
SEED_SUPER_ADMIN_PASSWORD=Thaikuku@1
SEED_SELLER_EMAIL=j97shop
SEED_SELLER_PASSWORD=Seller123!
SEED_SELLER_DISPLAY_NAME=J97 SHOP
SEED_SELLER_WALLET_BALANCE=0
SEED_SELLER_BOT_TOKEN=
SEED_SELLER_PROVIDER_KEY=
SEED_DEMO_DATA=false

MOCK_PROVIDER_ENABLED=false
MOCK_TELEGRAM_MODE=false

CATALOG_SYNC_INTERVAL_MS=60000
CATALOG_SCHEDULER_TICK_MS=5000
CATALOG_SHOPS_REFRESH_MS=60000
CATALOG_SYNC_CONCURRENCY=12
