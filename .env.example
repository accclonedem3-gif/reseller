SEED_SUPER_ADMIN_EMAIL=thaidem57
SEED_SUPER_ADMIN_PASSWORD=Thaikuku@1
SEED_SELLER_EMAIL=j97shop
SEED_SELLER_PASSWORD=Seller123!
SEED_SELLER_DISPLAY_NAME=J97 SHOP
SEED_SELLER_WALLET_BALANCE=0
SEED_SELLER_BOT_TOKEN=
SEED_SELLER_PROVIDER_KEY=
SEED_DEMO_DATA=false

MOCK_PROVIDER_ENABLED=false
MOCK_TELEGRAM_MODE=false

CATALOG_SYNC_INTERVAL_MS=60000
CATALOG_SCHEDULER_TICK_MS=5000
CATALOG_SHOPS_REFRESH_MS=60000
CATALOG_SYNC_CONCURRENCY=12
# CATALOG_SYNC_BATCH_SIZE=0
# CATALOG_SYNC_LOCK_TTL_MS=300000

# Warranty auto-check (3 sibling tools at ../check_veo, ../check_gpt, ../CheckGrokJS)
# Each tool must have `npm install` + Playwright/Puppeteer Chromium installed:
#   cd ../check_veo && npm install && npx playwright install chromium
#   cd ../check_gpt && npm install && npx playwright install chromium
#   cd ../CheckGrokJS && npm install   # uses local Chrome/Edge via puppeteer-core
# Override paths if tools live elsewhere:
# CHECK_VEO_PATH=/abs/path/to/check_veo/single-check.js
# CHECK_GROK_PATH=/abs/path/to/CheckGrokJS/single-check.js
# CHECK_GPT_PATH=/abs/path/to/check_gpt/single-check.js
ACCOUNT_CHECK_CONCURRENCY=3
ACCOUNT_CHECK_JOB_TIMEOUT_MS=90000
ACCOUNT_CHECK_SWEEP_INTERVAL_MS=60000

# Retry strategy:
#   ACCOUNT_CHECK_RETRY_COUNT (Pass 1) — retries when subprocess returns no parsed JSON
#     (timeout / parse error). Default 1 = 2 total attempts. Bounded by JOB_TIMEOUT_MS.
#   ACCOUNT_CHECK_AMBIGUOUS_RETRY (Pass 2) — retries when tool returns parsed JSON but the
#     verdict is unclear (Status=Unknown, login_stuck, cf_timeout, Pro/Premium plan etc.).
#     Default 2. Skipped for definitive errorTypes (wrong_password, 2fa, blocked, proxy_die)
#     to avoid lockouts / wasted slots.
# ACCOUNT_CHECK_RETRY_COUNT=1
# ACCOUNT_CHECK_AMBIGUOUS_RETRY=3

# Operator kill switch — comma-separated list of auto-check tools to disable. Disabled tools
# cause warranty submissions for that product family to fall through to UNSUPPORTED so the
# seller handles them manually. Use this when one tool is unstable (e.g. ChatGPT login flow
# breaking) without redeploying. Example: WARRANTY_DISABLED_TOOLS=gpt
# WARRANTY_DISABLED_TOOLS=

# Veo domain mass-die tracking (build 2026-05-25): once N veo accounts on the same email
# domain confirm dead, subsequent veo checks for that domain auto-mark dead without spawning
# Chromium. Saves 10-20s per account when a bulk-created lot has been banned upstream.
# VEO_DOMAIN_DEAD_THRESHOLD=20
# VEO_DOMAIN_DEAD_TTL_SEC=604800

# Grok HTTP fast-path (optional but recommended): nếu set, worker gửi grok
# checks tới long-running server.js của CheckGrokJS (CF cookie warmer 24/7,
# cookie share giữa khách → ~3s/acc thay vì ~20s cold-start subprocess).
# Khi không reachable, worker tự fallback về spawn single-check.js subprocess.
#
# Start the server với: `cd ../CheckGrokJS && PORT=4001 WARMER=1 node server.js`
# (hoặc dùng start-local.ps1 — script tự spin lên).
# CHECK_GROK_URL=http://127.0.0.1:4001
# CHECK_GROK_API_KEY=                 # set nếu server có API_KEY
# CHECK_GROK_POLL_MS=1500              # polling interval khi đợi kết quả
# CHECK_GROK_HTTP_TIMEOUT_MS=180000    # tổng timeout cho 1 batch (default 3 phút)

# Veo HTTP fast-path (same pattern as grok): worker POSTs batch to long-running
# check_veo/server.js which holds a Chromium browser pool. Each check skips the ~3-5s
# cold launch tax → ~30s warm vs ~45s subprocess. Fallback to subprocess if server down.
#
# Start: `cd ../check_veo && PORT=4002 node server.js`  (or via npm run dev concurrently)
# CHECK_VEO_URL=http://127.0.0.1:4002
# CHECK_VEO_API_KEY=                  # set nếu server bật API_KEY
# CHECK_VEO_HTTP_TIMEOUT_MS=180000     # tổng timeout 1 batch
# CHECK_VEO_POOL_MAX=2                 # browsers in pool (4GB VPS: 2, 8GB+: 3)
