generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SELLER
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum SellerStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum SellerTier {
  FREE
  PRO
  ULTRA
}

enum ProviderKind {
  EXTERNAL
  INTERNAL
}

enum ShopStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum StorefrontMode {
  TELEGRAM_ONLY
  HYBRID
  WEB_ONLY
}

enum ConnectionStatus {
  PENDING
  VERIFIED
  FAILED
  DISABLED
}

enum WebhookStatus {
  DISABLED
  PENDING
  ACTIVE
  FAILED
  POLLING
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  PROCESSING_PURCHASE
  DELIVERED
  FAILED
  PAID_WAITING_STOCK
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum WalletLedgerType {
  TOPUP
  DEBIT_PURCHASE
  REFUND_PURCHASE
  WITHDRAW
  ADJUST
  WITHDRAW_REJECT_REFUND
  SALE_REVENUE
  AFFILIATE_LEVEL_1
  AFFILIATE_LEVEL_2
  AFFILIATE_CLAWBACK
  SUBSCRIPTION_PAYMENT
}

enum TierPlan {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum TierSubscriptionStatus {
  ACTIVE
  EXPIRED
  REFUNDED
  CANCELED
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BroadcastStatus {
  DRAFT
  QUEUED
  SENDING
  COMPLETED
  FAILED
  SCHEDULED
}

enum BroadcastLogStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentProvider {
  PAYOS
  PAY2S
  WEB2M
  MOCK
  BINANCE
  OKX
  USDT_TRC20
  USDT_SOL
  BINANCE_PAY
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum CustomerWalletLedgerType {
  TOPUP
  TOPUP_BONUS
  SPEND_ORDER
  REFUND_ORDER
  ADJUST
  AFFILIATE_COMMISSION
}

enum TelegramDeliveryMode {
  WEBHOOK
  POLLING
}

enum InternalSourceApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DownstreamSourceConnectionStatus {
  PENDING
  ACTIVE
  DISABLED
  REVOKED
}

enum InternalSourceLedgerType {
  TOPUP
  DEBIT_ORDER
  REFUND_ORDER
  ADJUST
}

enum InternalSourceOrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  PENDING_STOCK
  PENDING_MANUAL
  FAILED
  CANCELED
}

enum SourceProductFamily {
  CHATGPT
  VEO3
  CLAUDE
  GEMINI
  CANVA
  CAPCUT
  GROK
  KLING
  ADOBE
  SUNO
  HEYGEN
  PERPLEXITY
  GMAIL
  ELEVENLABS
  TIKTOK
  DUOLINGO
  HMA
  VPN
  ZOOM
  YOUTUBE
  HIGGSFIELD
  OTHER
}

enum SourceAccountType {
  PERSONAL
  SHARED
  ADD_FAMILY
  CREDIT_API
  OTHER
}

enum SourceDurationType {
  DAY_1
  DAY_7
  MONTH_1
  MONTH_3
  MONTH_6
  MONTH_12
  LIFETIME
  OTHER
}

enum SourceDeliveryMode {
  AUTO_API
  AUTO_STOCK
  MANUAL
}

enum SourceWarrantyPolicy {
  KBH
  BH24H
  BH1M
  BH3M
  BH6M
  BH12M
  BHF
}

enum StockOperationType {
  UPLOAD
  EXTRACT
  PREVIEW
}

enum StockExtractMethod {
  FIFO
  LIFO
  RANDOM
  RANGE
  MANUAL
}

enum ConnectionTopupStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
}

enum WarrantyClaimStatus {
  PENDING
  AUTO_RESOLVED
  PENDING_STOCK
  PENDING_REVIEW
  PENDING_MANUAL
  REJECTED
  RESOLVED_MANUAL
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  recoveryEmail        String?              @unique @map("recovery_email")
  passwordHash         String               @map("password_hash")
  role                 UserRole
  status               UserStatus           @default(ACTIVE)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  seller               Seller?
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  reviewedDeposits     DepositRequest[]     @relation("DepositReviewedBy")
  reviewedWithdraws    WithdrawRequest[]    @relation("WithdrawReviewedBy")
  createdDiscountCodes DiscountCode[]       @relation("DiscountCodeCreator")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Seller {
  id                          String                       @id @default(cuid())
  userId                      String                       @unique @map("user_id")
  displayName                 String                       @map("display_name")
  phone                       String?
  status                      SellerStatus                 @default(ACTIVE)
  tier                        SellerTier                   @default(PRO)
  tierStartedAt               DateTime?                    @map("tier_started_at")
  tierExpiresAt               DateTime?                    @map("tier_expires_at")
  lastTierReminderStage       String?                      @map("last_tier_reminder_stage")
  lastTierReminderAt          DateTime?                    @map("last_tier_reminder_at")
  referredBySellerId          String?                      @map("referred_by_seller_id")
  referralCode                String?                      @unique @map("referral_code")
  affiliateUnlockedTier       Int                          @default(1) @map("affiliate_unlocked_tier")
  affiliateUnlockedTier2At    DateTime?                    @map("affiliate_unlocked_tier_2_at")
  affiliateUnlockedTier3At    DateTime?                    @map("affiliate_unlocked_tier_3_at")
  autoRenewConfig             Json?                        @map("auto_renew_config")
  signupIp                    String?                      @map("signup_ip")
  signupDeviceFingerprint     String?                      @map("signup_device_fingerprint")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet                      SellerWallet?
  shops                       Shop[]
  productOverrides            SellerProductOverride[]
  customers                   Customer[]
  orders                      Order[]
  ledgers                     WalletLedger[]
  deposits                    DepositRequest[]
  withdraws                   WithdrawRequest[]
  broadcasts                  Broadcast[]
  broadcastSchedules          BroadcastSchedule[]
  ownedDiscountCodes          DiscountCode[]               @relation("DiscountCodeReferrer")
  discountCodeUsages          DiscountCodeUsage[]          @relation("DiscountCodeUsageSeller")
  sourceApiKeys               InternalSourceApiKey[]       @relation("SourceApiKeyOwner")
  upstreamSourceConnections   DownstreamSourceConnection[] @relation("UpstreamSellerConnections")
  downstreamSourceConnections DownstreamSourceConnection[] @relation("DownstreamSellerConnections")
  upstreamSourceOrders        InternalSourceOrder[]        @relation("InternalSourceOrderUpstreamSeller")
  downstreamSourceOrders      InternalSourceOrder[]        @relation("InternalSourceOrderDownstreamSeller")
  warrantyClaims              WarrantyClaim[]
  affiliateConfigs            AffiliateConfig[]
  referredBy                  Seller?                      @relation("SellerReferral", fields: [referredBySellerId], references: [id])
  referrals                   Seller[]                     @relation("SellerReferral")
  tierSubscriptions           TierSubscription[]           @relation("TierSubscriptionSeller")
  level1Subscriptions         TierSubscription[]           @relation("TierSubscriptionLevel1Referrer")
  level2Subscriptions         TierSubscription[]           @relation("TierSubscriptionLevel2Referrer")

  @@map("sellers")
}

model TierSubscription {
  id                    String                 @id @default(cuid())
  sellerId              String                 @map("seller_id")
  tier                  SellerTier
  plan                  TierPlan
  priceVnd              Decimal                @map("price_vnd") @db.Decimal(18, 2)
  startsAt              DateTime               @map("starts_at")
  endsAt                DateTime               @map("ends_at")
  status                TierSubscriptionStatus @default(ACTIVE)
  paymentMethod         String?                @map("payment_method")
  paymentTransactionId  String?                @map("payment_transaction_id")
  paidFromWalletBalance Boolean                @default(false) @map("paid_from_wallet_balance")
  referrerSellerId      String?                @map("referrer_seller_id")
  grandReferrerSellerId String?                @map("grand_referrer_seller_id")
  level1Rate            Decimal?               @map("level_1_rate") @db.Decimal(5, 4)
  level2Rate            Decimal?               @map("level_2_rate") @db.Decimal(5, 4)
  level1CommissionVnd   Decimal?               @map("level_1_commission_vnd") @db.Decimal(18, 2)
  level2CommissionVnd   Decimal?               @map("level_2_commission_vnd") @db.Decimal(18, 2)
  refundedAt            DateTime?              @map("refunded_at")
  isAdminGrant          Boolean                @default(false) @map("is_admin_grant")
  adminGrantNote        String?                @map("admin_grant_note")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  seller                Seller                 @relation("TierSubscriptionSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  referrerSeller        Seller?                @relation("TierSubscriptionLevel1Referrer", fields: [referrerSellerId], references: [id])
  grandReferrerSeller   Seller?                @relation("TierSubscriptionLevel2Referrer", fields: [grandReferrerSellerId], references: [id])
  discountCodeUsage     DiscountCodeUsage?

  @@index([sellerId, status])
  @@index([endsAt, status])
  @@index([referrerSellerId])
  @@map("tier_subscriptions")
}

model DiscountCode {
  id               String              @id @default(cuid())
  code             String              @unique
  discountPercent  Decimal             @map("discount_percent") @db.Decimal(5, 2)
  description      String?
  referrerSellerId String              @map("referrer_seller_id")
  active           Boolean             @default(true)
  createdByUserId  String              @map("created_by_user_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  referrerSeller   Seller              @relation("DiscountCodeReferrer", fields: [referrerSellerId], references: [id], onDelete: Restrict)
  createdBy        User                @relation("DiscountCodeCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  usages           DiscountCodeUsage[]

  @@index([referrerSellerId])
  @@index([active])
  @@map("discount_codes")
}

model DiscountCodeUsage {
  id               String            @id @default(cuid())
  discountCodeId   String            @map("discount_code_id")
  sellerId         String            @map("seller_id")
  subscriptionId   String?           @unique @map("subscription_id")
  amountDiscounted Decimal           @map("amount_discounted") @db.Decimal(18, 2)
  usedAt           DateTime          @default(now()) @map("used_at")
  discountCode     DiscountCode      @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  seller           Seller            @relation("DiscountCodeUsageSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  subscription     TierSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([discountCodeId, sellerId])
  @@index([sellerId])
  @@map("discount_code_usages")
}

model Shop {
  id                          String                       @id @default(cuid())
  sellerId                    String                       @map("seller_id")
  slug                        String                       @unique
  name                        String
  tagline                     String?
  logoUrl                     String?                      @map("logo_url")
  supportTelegram             String?                      @map("support_telegram")
  supportZalo                 String?                      @map("support_zalo")
  status                      ShopStatus                   @default(DRAFT)
  storefrontMode              StorefrontMode               @default(TELEGRAM_ONLY) @map("storefront_mode")
  storefrontConfigJson        Json?                        @map("storefront_config_json")
  defaultCurrency             String                       @default("VND") @map("default_currency")
  isTemplate                  Boolean                      @default(false) @map("is_template")
  lastCatalogSyncAt           DateTime?                    @map("last_catalog_sync_at")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  seller                      Seller                       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  botConfig                   BotConfig?
  providerConfig              ProviderConfig?
  paymentConfig               PaymentConfig?
  sourceProducts              SourceProduct[]
  productOverrides            SellerProductOverride[]
  customers                   Customer[]
  orders                      Order[]
  broadcasts                  Broadcast[]
  broadcastSchedules          BroadcastSchedule[]
  customerWalletTopups        CustomerWalletTopup[]
  sourceApiKeys               InternalSourceApiKey[]       @relation("SourceApiKeyShop")
  upstreamSourceConnections   DownstreamSourceConnection[] @relation("UpstreamShopConnections")
  downstreamSourceConnections DownstreamSourceConnection[] @relation("DownstreamShopConnections")
  upstreamSourceOrders        InternalSourceOrder[]        @relation("InternalSourceOrderUpstreamShop")
  downstreamSourceOrders      InternalSourceOrder[]        @relation("InternalSourceOrderDownstreamShop")
  warrantyClaims              WarrantyClaim[]
  upstreamTopupRequests       ConnectionTopupRequest[]     @relation("UpstreamShopTopups")
  downstreamTopupRequests     ConnectionTopupRequest[]     @relation("DownstreamShopTopups")
  affiliateConfig             AffiliateConfig?
  catalogGroups               ShopCatalogGroup[]
  walletPromotions            WalletPromotion[]
  iconCatalog                 IconCatalog[]
  botMediaCache               BotMediaCache[]

  @@map("shops")
}

model BotConfig {
  id                        String               @id @default(cuid())
  shopId                    String               @unique @map("shop_id")
  telegramBotTokenEncrypted String               @map("telegram_bot_token_encrypted")
  telegramBotId             String?              @map("telegram_bot_id")
  telegramBotUsername       String?              @map("telegram_bot_username")
  ownerTelegramUserId       String?              @map("owner_telegram_user_id")
  customizationJson         Json?                @map("customization_json")
  isGlobalDefault           Boolean              @default(false) @map("is_global_default")
  webhookUrl                String?              @map("webhook_url")
  webhookStatus             WebhookStatus        @default(DISABLED) @map("webhook_status")
  deliveryMode              TelegramDeliveryMode @default(POLLING) @map("delivery_mode")
  lastVerifiedAt            DateTime?            @map("last_verified_at")
  lastProcessedUpdateId     BigInt?              @map("last_processed_update_id")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  shop                      Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

model ProviderConfig {
  id                            String                      @id @default(cuid())
  shopId                        String                      @unique @map("shop_id")
  providerKind                  ProviderKind                @default(EXTERNAL) @map("provider_kind")
  providerName                  String                      @default("canboso") @map("provider_name")
  baseUrl                       String                      @default("https://canboso.com") @map("base_url")
  buyerKeyEncrypted             String                      @map("buyer_key_encrypted")
  internalSourceConnectionId    String?                     @unique @map("internal_source_connection_id")
  sourceWebhookKey              String?                     @unique @map("source_webhook_key")
  sourceNotificationSyncEnabled Boolean                     @default(true) @map("source_notification_sync_enabled")
  priceMarkupPercent            Decimal?                    @map("price_markup_percent") @db.Decimal(5, 2)
  connectionStatus              ConnectionStatus            @default(PENDING) @map("connection_status")
  lastVerifiedAt                DateTime?                   @map("last_verified_at")
  createdAt                     DateTime                    @default(now()) @map("created_at")
  updatedAt                     DateTime                    @updatedAt @map("updated_at")
  shop                          Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  internalSourceConnection      DownstreamSourceConnection? @relation(fields: [internalSourceConnectionId], references: [id], onDelete: SetNull)

  @@map("provider_configs")
}

model PaymentConfig {
  id                                String          @id @default(cuid())
  shopId                            String          @unique @map("shop_id")
  provider                          PaymentProvider @default(MOCK)
  payosClientIdEncrypted            String?         @map("payos_client_id_encrypted")
  payosApiKeyEncrypted              String?         @map("payos_api_key_encrypted")
  payosChecksumKeyEncrypted         String?         @map("payos_checksum_key_encrypted")
  pay2sPartnerCodeEncrypted         String?         @map("pay2s_partner_code_encrypted")
  pay2sAccessKeyEncrypted           String?         @map("pay2s_access_key_encrypted")
  pay2sSecretKeyEncrypted           String?         @map("pay2s_secret_key_encrypted")
  pay2sBankAccount                  String?         @map("pay2s_bank_account")
  pay2sBankId                       String?         @map("pay2s_bank_id")
  pay2sWebhookTokenEncrypted        String?         @map("pay2s_webhook_token_encrypted")
  web2mAccountNumber                String?         @map("web2m_account_number")
  web2mBankCode                     String?         @map("web2m_bank_code")
  web2mPasswordEncrypted            String?         @map("web2m_password_encrypted")
  web2mTokenEncrypted               String?         @map("web2m_token_encrypted")
  web2mAccessTokenEncrypted         String?         @map("web2m_access_token_encrypted")
  binanceUid                        String?         @map("binance_uid")
  okxUid                            String?         @map("okx_uid")
  usdtTrc20Address                  String?         @map("usdt_trc20_address")
  usdtBep20Address                  String?         @map("usdt_bep20_address")
  usdtSolanaAddress                 String?         @map("usdt_solana_address")
  usdtVndRateOverride               Decimal?        @map("usdt_vnd_rate_override") @db.Decimal(18, 2)
  // Binance Pay Merchant API (auto flow) — DEPRECATED, UI hidden but kept in DB
  binancePayApiKeyEncrypted         String?         @map("binance_pay_api_key_encrypted")
  binancePaySecretKeyEncrypted      String?         @map("binance_pay_secret_key_encrypted")
  binancePayEnabled                 Boolean         @default(false) @map("binance_pay_enabled")
  // Binance Personal API (Spot API for UID auto verification)
  binancePersonalApiKeyEncrypted    String?         @map("binance_personal_api_key_encrypted")
  binancePersonalSecretKeyEncrypted String?         @map("binance_personal_secret_key_encrypted")
  // OKX Personal API (Read-only API for auto deposit verification)
  okxPersonalApiKeyEncrypted        String?         @map("okx_personal_api_key_encrypted")
  okxPersonalSecretKeyEncrypted     String?         @map("okx_personal_secret_key_encrypted")
  okxPersonalPassphraseEncrypted    String?         @map("okx_personal_passphrase_encrypted")
  okxPersonalApiEnabled             Boolean         @default(false) @map("okx_personal_api_enabled")
  createdAt                         DateTime        @default(now()) @map("created_at")
  updatedAt                         DateTime        @updatedAt @map("updated_at")
  shop                              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("payment_configs")
}

model SellerWallet {
  id        String         @id @default(cuid())
  sellerId  String         @unique @map("seller_id")
  balance   Decimal        @db.Decimal(18, 2)
  currency  String         @default("VND")
  updatedAt DateTime       @updatedAt @map("updated_at")
  createdAt DateTime       @default(now()) @map("created_at")
  seller    Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  ledgers   WalletLedger[]

  @@map("seller_wallets")
}

model WalletLedger {
  id            String           @id @default(cuid())
  sellerId      String           @map("seller_id")
  walletId      String           @map("wallet_id")
  type          WalletLedgerType
  amount        Decimal          @db.Decimal(18, 2)
  balanceBefore Decimal          @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal          @map("balance_after") @db.Decimal(18, 2)
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id")
  note          String?
  createdAt     DateTime         @default(now()) @map("created_at")
  seller        Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  wallet        SellerWallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@map("wallet_ledgers")
}

model SourceProduct {
  id                      String                  @id @default(cuid())
  shopId                  String                  @map("shop_id")
  externalProductId       String                  @map("external_product_id")
  providerName            String                  @default("canboso") @map("provider_name")
  sourceName              String                  @map("source_name")
  sourceRawName           String?                 @map("source_raw_name")
  sourceDescription       String?                 @map("source_description")
  sourceDescriptionLocked Boolean                 @default(false) @map("source_description_locked")
  sourcePrice             Decimal                 @map("source_price") @db.Decimal(18, 2)
  available               Int?
  soldCount               Int                     @default(0) @map("sold_count")
  totalCount              Int                     @default(0) @map("total_count")
  internalSourceEnabled   Boolean                 @default(false) @map("internal_source_enabled")
  internalSourcePrice     Decimal?                @map("internal_source_price") @db.Decimal(18, 2)
  productFamily           String?                 @map("product_family")
  productFamilyOther      String?                 @map("product_family_other")
  productPackage          String?                 @map("product_package")
  accountType             SourceAccountType?      @map("account_type")
  accountTypeOther        String?                 @map("account_type_other")
  durationType            SourceDurationType?     @map("duration_type")
  durationTypeOther       String?                 @map("duration_type_other")
  // Warranty pre-die date (from warranty branch): declared lifetime (days) of the current batch,
  // counted from accBatchStartedAt (import time), NOT delivery. When set + elapsed → warranty
  // short-circuits the auto-check tool with a synthetic isDead verdict. Falls back to deliveredAt.
  accLifetimeDays         Int?                    @map("acc_lifetime_days")
  accBatchStartedAt       DateTime?               @map("acc_batch_started_at")
  productIcon             String?                 @map("product_icon")
  iconCustomEmojiId       String?                 @map("icon_custom_emoji_id")
  iconOutOfStockEmojiId   String?                 @map("icon_out_of_stock_emoji_id")
  imageUrl                String?                 @map("image_url")
  isSample                Boolean                 @default(false) @map("is_sample")
  sourceDeliveryMode      SourceDeliveryMode?     @map("source_delivery_mode")
  warrantyPolicy          SourceWarrantyPolicy?   @map("warranty_policy")
  stockAlertThreshold     Int                     @default(5) @map("stock_alert_threshold")
  stockAlertEnabled       Boolean                 @default(true) @map("stock_alert_enabled")
  lastStockAlertAt        DateTime?               @map("last_stock_alert_at")
  promoType               String?                 @map("promo_type") // "BUY_N_GET_M" | "BULK_DISCOUNT"
  promoBuyN               Int?                    @map("promo_buy_n")
  promoGetM               Int?                    @map("promo_get_m")
  promoBulkMinQty         Int?                    @map("promo_bulk_min_qty")
  promoBulkDiscountPct    Decimal?                @map("promo_bulk_discount_pct") @db.Decimal(5, 2)
  promoStartAt            DateTime?               @map("promo_start_at")
  promoEndAt              DateTime?               @map("promo_end_at")
  promoBannerUrl          String?                 @map("promo_banner_url")
  metadataJson            Json?                   @map("metadata_json")
  syncedAt                DateTime                @default(now()) @map("synced_at")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  shop                    Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  overrides               SellerProductOverride[]
  orders                  Order[]
  internalSourceOrders    InternalSourceOrder[]
  operations              ProductStockOperation[]
  stockBatches            StockBatch[]
  stockEntries            StockEntry[]

  @@unique([shopId, externalProductId])
  @@map("source_products")
}

/// Admin-managed catalog of product families (replaces the old hardcoded
/// SourceProductFamily enum). `key` is what gets stored on
/// SourceProduct.productFamily; built-in rows are seeded + cannot be deleted.
model ProductFamily {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  emoji         String?
  customEmojiId String?  @map("custom_emoji_id")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  isBuiltin     Boolean  @default(false) @map("is_builtin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("product_families")
}

enum StockEntryStatus {
  AVAILABLE
  SOLD
  EXTRACTED
}

model StockBatch {
  id              String        @id @default(cuid())
  sourceProductId String        @map("source_product_id")
  name            String
  costPerUnit     Decimal?      @map("cost_per_unit") @db.Decimal(18, 2)
  expiresAt       DateTime?     @map("expires_at")
  priority        Int           @default(0)
  createdAt       DateTime      @default(now()) @map("created_at")
  deletedAt       DateTime?     @map("deleted_at")
  sourceProduct   SourceProduct @relation(fields: [sourceProductId], references: [id], onDelete: Cascade)
  entries         StockEntry[]

  @@index([sourceProductId, createdAt])
  @@index([sourceProductId, deletedAt])
  @@index([sourceProductId, priority, createdAt])
  @@map("stock_batches")
}

model StockEntry {
  id               String           @id @default(cuid())
  sourceProductId  String           @map("source_product_id")
  batchId          String?          @map("batch_id")
  text             String
  status           StockEntryStatus @default(AVAILABLE)
  uploadedAt       DateTime         @default(now()) @map("uploaded_at")
  soldAt           DateTime?        @map("sold_at")
  soldToOrderId    String?          @map("sold_to_order_id")
  soldToCustomerId String?          @map("sold_to_customer_id")
  extractedAt      DateTime?        @map("extracted_at")
  sourceProduct    SourceProduct    @relation(fields: [sourceProductId], references: [id], onDelete: Cascade)
  batch            StockBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  soldToOrder      Order?           @relation("OrderStockEntries", fields: [soldToOrderId], references: [id], onDelete: SetNull)
  soldToCustomer   Customer?        @relation("CustomerPurchasedEntries", fields: [soldToCustomerId], references: [id], onDelete: SetNull)

  @@index([sourceProductId, status, uploadedAt])
  @@index([batchId, status])
  @@index([soldToOrderId])
  @@index([soldToCustomerId])
  @@map("stock_entries")
}

model ProductStockOperation {
  id               String              @id @default(cuid())
  sourceProductId  String              @map("source_product_id")
  operationType    StockOperationType  @map("operation_type")
  extractMethod    StockExtractMethod? @map("extract_method")
  quantity         Int
  availableBefore  Int                 @map("available_before")
  availableAfter   Int                 @map("available_after")
  payloadJson      Json?               @map("payload_json")
  createdAt        DateTime            @default(now()) @map("created_at")
  sourceProduct    SourceProduct       @relation(fields: [sourceProductId], references: [id], onDelete: Cascade)

  @@index([sourceProductId, createdAt])
  @@map("product_stock_operations")
}

model SellerProductOverride {
