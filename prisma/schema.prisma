model Order {
  id                           String                @id @default(cuid())
  shopId                       String                @map("shop_id")
  sellerId                     String                @map("seller_id")
  customerId                   String                @map("customer_id")
  orderCode                    String                @unique @map("order_code")
  sourceProductId              String                @map("source_product_id")
  sourceProviderKindSnapshot   ProviderKind?         @map("source_provider_kind_snapshot")
  internalSourceOrderId        String?               @unique @map("internal_source_order_id")
  internalSourceOrderCode      String?               @map("internal_source_order_code")
  warrantyPolicySnapshot       SourceWarrantyPolicy? @map("warranty_policy_snapshot")
  warrantyDeliveryModeSnapshot SourceDeliveryMode?   @map("warranty_delivery_mode_snapshot")
  warrantyStartedAt            DateTime?             @map("warranty_started_at")
  warrantyExpiresAt            DateTime?             @map("warranty_expires_at")
  warrantyClaimCount           Int                   @default(0) @map("warranty_claim_count")
  // Per-order warranty secret (from warranty branch); nullable for legacy orders. Generated at order create.
  warrantyClaimCode            String?               @map("warranty_claim_code")
  productNameSnapshot          String                @map("product_name_snapshot")
  quantity                     Int                   @default(1)
  salePrice                    Decimal               @map("sale_price") @db.Decimal(18, 2)
  sourcePriceSnapshot          Decimal               @map("source_price_snapshot") @db.Decimal(18, 2)
  totalSaleAmount              Decimal               @map("total_sale_amount") @db.Decimal(18, 2)
  totalSourceAmount            Decimal               @map("total_source_amount") @db.Decimal(18, 2)
  status                       OrderStatus           @default(AWAITING_PAYMENT)
  paymentStatus                PaymentStatus         @default(UNPAID) @map("payment_status")
  deliveredAccountText         String?               @map("delivered_account_text")
  failureReason                String?               @map("failure_reason")
  affiliateCustomerId          String?               @map("affiliate_customer_id")
  affiliateCommission          Decimal?              @map("affiliate_commission") @db.Decimal(18, 2)
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")
  paidAt                       DateTime?             @map("paid_at")
  deliveredAt                  DateTime?             @map("delivered_at")
  shop                         Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  seller                       Seller                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  customer                     Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  affiliateCustomer            Customer?             @relation("OrderAffiliate", fields: [affiliateCustomerId], references: [id], onDelete: SetNull)
  sourceProduct                SourceProduct         @relation(fields: [sourceProductId], references: [id], onDelete: Restrict)
  internalSourceOrder          InternalSourceOrder?  @relation(fields: [internalSourceOrderId], references: [id], onDelete: SetNull)
  events                       OrderEvent[]
  paymentTransaction           PaymentTransaction?
  warrantyClaims               WarrantyClaim[]
  stockEntries                 StockEntry[]          @relation("OrderStockEntries")

  @@index([sellerId, createdAt])
  @@index([shopId, status])
  @@map("orders")
}

model OrderEvent {
