  rawPayloadJson      Json?                    @map("raw_payload_json")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  paidAt              DateTime?                @map("paid_at")
  order               Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model DepositRequest {
  id                String          @id @default(cuid())
  sellerId          String          @map("seller_id")
  amount            Decimal         @db.Decimal(18, 2)
  status            DepositStatus   @default(PENDING)
  provider          PaymentProvider @default(PAYOS)
  externalOrderCode String?         @unique @map("external_order_code")
  checkoutUrl       String?         @map("checkout_url")
  qrCode            String?         @map("qr_code")
  expiresAt         DateTime?       @map("expires_at")
  paidAt            DateTime?       @map("paid_at")
  note              String?
  rawPayloadJson    Json?           @map("raw_payload_json")
  approvedById      String?         @map("approved_by_id")
  approvedAt        DateTime?       @map("approved_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  seller            Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  approvedBy        User?           @relation("DepositReviewedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("deposit_requests")
}

model WithdrawRequest {
  id                String         @id @default(cuid())
  sellerId          String         @map("seller_id")
  amount            Decimal        @db.Decimal(18, 2)
  bankName          String?        @map("bank_name")
  bankAccountNumber String?        @map("bank_account_number")
  bankAccountName   String?        @map("bank_account_name")
  note              String?
  status            WithdrawStatus @default(PENDING)
  reviewedById      String?        @map("reviewed_by_id")
  reviewedAt        DateTime?      @map("reviewed_at")
  rejectReason      String?        @map("reject_reason")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  seller            Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  reviewedBy        User?          @relation("WithdrawReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("withdraw_requests")
}

model Broadcast {
  id           String             @id @default(cuid())
  shopId       String             @map("shop_id")
  sellerId     String             @map("seller_id")
  scheduleId   String?            @map("schedule_id")
  title        String?
  message      String
  imageUrl     String?            @map("image_url")
  status       BroadcastStatus    @default(DRAFT)
  totalTargets Int                @default(0) @map("total_targets")
  sentCount    Int                @default(0) @map("sent_count")
  failedCount  Int                @default(0) @map("failed_count")
  scheduledAt  DateTime?          @map("scheduled_at")
  sentAt       DateTime?          @map("sent_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  shop         Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  seller       Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  schedule     BroadcastSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  logs         BroadcastLog[]

  @@map("broadcasts")
}

model BroadcastSchedule {
  id         String      @id @default(cuid())
  shopId     String      @map("shop_id")
  sellerId   String      @map("seller_id")
  title      String?
  message    String
  imageUrl   String?     @map("image_url")
  sendTime   String      @map("send_time")
  frequency  String      @default("daily")
  repeatDay  Int?        @map("repeat_day")
  isActive   Boolean     @default(true) @map("is_active")
  lastRunAt  DateTime?   @map("last_run_at")
  nextRunAt  DateTime?   @map("next_run_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  shop       Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  seller     Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  broadcasts Broadcast[]

  @@map("broadcast_schedules")
}

model BroadcastLog {
  id              String             @id @default(cuid())
  broadcastId     String             @map("broadcast_id")
  customerId      String             @map("customer_id")
  status          BroadcastLogStatus @default(PENDING)
  errorMessage    String?            @map("error_message")
  rawResponseJson Json?              @map("raw_response_json")
  sentAt          DateTime?          @map("sent_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  broadcast       Broadcast          @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, customerId])
  @@map("broadcast_logs")
}

model ReferralLink {
  id        String          @id @default(cuid())
  shopId    String          @map("shop_id")
  sellerId  String          @map("seller_id")
  code      String          @unique
  label     String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  events    ReferralEvent[]

  @@map("referral_links")
}

model ReferralEvent {
  id             String       @id @default(cuid())
  referralLinkId String       @map("referral_link_id")
  customerId     String?      @map("customer_id")
  eventType      String       @map("event_type")
  payloadJson    Json?        @map("payload_json")
  createdAt      DateTime     @default(now()) @map("created_at")
  referralLink   ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@map("referral_events")
}

model ConnectionTopupRequest {
  id                String                @id @default(cuid())
  connectionId      String                @map("connection_id")
  upstreamShopId    String                @map("upstream_shop_id")
  downstreamShopId  String                @map("downstream_shop_id")
  amount            Decimal               @db.Decimal(18, 2)
  provider          PaymentProvider
  externalOrderCode String                @unique @map("external_order_code")
  status            ConnectionTopupStatus @default(PENDING)
  checkoutUrl       String?               @map("checkout_url")
  qrCode            String?               @map("qr_code")
  expiresAt         DateTime?             @map("expires_at")
  rawPayloadJson    Json?                 @map("raw_payload_json")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  connection     DownstreamSourceConnection @relation(fields: [connectionId], references: [id])
  upstreamShop   Shop                       @relation("UpstreamShopTopups", fields: [upstreamShopId], references: [id])
  downstreamShop Shop                       @relation("DownstreamShopTopups", fields: [downstreamShopId], references: [id])

  @@index([connectionId, createdAt])
  @@map("connection_topup_requests")
}

model AffiliateConfig {
  id            String   @id @default(cuid())
  shopId        String   @unique @map("shop_id")
  sellerId      String   @map("seller_id")
  enabled       Boolean  @default(false)
  commissionPct Decimal  @default(0) @map("commission_pct") @db.Decimal(5, 2)
  programText   String?  @map("program_text")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  seller        Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("affiliate_configs")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model WalletPromotion {
  id           String   @id @default(cuid())
  shopId       String   @map("shop_id")
  bonusPercent Decimal  @map("bonus_percent") @db.Decimal(5, 2)
  startAt      DateTime @map("start_at")
  endAt        DateTime @map("end_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, startAt, endAt])
  @@map("wallet_promotions")
}
